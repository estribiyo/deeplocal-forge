# rag-bot — Bot de consultas sobre documentos
# Rol: RAG con adherencia estricta al contexto, sin conocimiento propio
# Uso: Langflow / n8n → Qdrant → este modelo
# temperature 0.0 — totalmente determinista, obligatorio en RAG anti-alucinación
# num_keep 64 — mantiene el system prompt de restricción en KV cache entre turnos

FROM qwen2.5:7b-instruct
PARAMETER num_ctx     32768
PARAMETER temperature 0.0
PARAMETER num_keep    64
