# ── GENERAL ───────────────────────────────────────────────────────────────────
MAIN_DOMAIN=dominio.local
PROFILE_VAR=cpu

# ── OLLAMA ────────────────────────────────────────────────────────────────────
LLM_API_BASE="http://ollama:11434"
LLM_MODEL_NAME="deepseek-r1:14b"
LLM_EMBEDDING_MODEL_NAME="nomic-embed-text"
LLM_TOOLS_MODEL_NAME="qwen2.5:7b-instruct"

# ── TTS (Coqui) ───────────────────────────────────────────────────────────────
TTS_API_URL=http://tts:5002
TTS_MODEL=tts_models/es/css10/vits
COQUI_CPU_IMAGE=ghcr.io/coqui-ai/tts-cpu
COQUI_GPU_IMAGE=ghcr.io/coqui-ai/tts

# ── STT (Whisper) ─────────────────────────────────────────────────────────────
STT_API_URL=http://stt:9000
# Necesario para algunos modelos Whisper — obtenerlo en huggingface.co/settings/tokens
# HF_TOKEN=

# ── COMFYUI ───────────────────────────────────────────────────────────────────
COMFY_PATH=/comfy
COMFYUI_API_URL=http://comfyui:8188

# ── MCP SERVERS ───────────────────────────────────────────────────────────────
MCP_FS_PATH_1=./data/docs
MCP_FS_PATH_2=./data/exports
# Solo necesaria con: just up-mcp-optional
MCP_SEARXNG_URL=https://search.tudominio.local
